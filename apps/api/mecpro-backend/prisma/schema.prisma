generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////// ENUMS ////////////////////
enum TenantStatus {
  ACTIVE
  BLOCKED
  CANCELED
}

enum UserRole {
  OWNER
  ADMIN
  SUPER_ADMIN
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum EstimateStatus {
  DRAFT
  SENT
  APPROVED
  CONVERTED
}

enum InvoiceStatus {
  PENDING
  PAID
  CANCELED
}

//////////////////// CONTACT MESSAGES (FAQ) ////////////////////
model ContactMessage {
  id        Int      @id @default(autoincrement())
  tenantId  String?  // se o usuário estiver autenticado, podemos vincular ao tenant
  userEmail String?  // email do usuário que enviou (pode ser extraído do token ou do form)
  userName  String?  // nome do usuário (opcional, pode vir do contexto)
  message   String   @db.Text
  status    String   @default("pending") // pending, replied, archived
  reply     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
}

//////////////////// TENANT (Oficina) ////////////////////
model Tenant {
  id             String       @id @default(uuid())
  name           String
  documentType   String
  documentNumber String       @unique
  cep            String
  address        String
  email          String
  phone          String
  logoUrl        String?
  status         TenantStatus @default(ACTIVE)
  trialEndsAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  users         User[]
  clients       Client[]
  subscriptions Subscription[]
  payments      Payment[]
  estimates     Estimate[]
  invoices      Invoice[]
  appointments  Appointment[]
  notifications Notification[]
  scheduledNotifications ScheduledNotification[]
  contactMessages ContactMessage[]

  @@index([status])
}

//////////////////// USUÁRIOS (proprietários e admins da oficina) ////////////////////
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(OWNER)
  tenantId  String?  // opcional para permitir SUPER_ADMIN sem tenant
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients       Client[]
  refreshTokens RefreshToken[]
}

//////////////////// SUPER ADMIN (opcional) ////////////////////
model SuperAdmin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

//////////////////// SUBSCRIPTIONS ////////////////////
model Subscription {
  id                    String      @id @default(uuid())
  tenantId              String
  tenant                Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planName              String
  price                 Float
  status                SubscriptionStatus
  gateway               String
  gatewaySubscriptionId String?
  startDate             DateTime
  endDate               DateTime?
  payments              Payment[]

  createdAt DateTime @default(now())
}

//////////////////// PAYMENTS ////////////////////
model Payment {
  id             String        @id @default(uuid())
  tenantId       String
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  amount         Float
  status         PaymentStatus
  gatewayPaymentId String?
  paidAt         DateTime?
  createdAt      DateTime @default(now())

  @@index([status])
}

//////////////////// CLIENTES ////////////////////
model Client {
  id        Int      @id @default(autoincrement())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])

  name      String
  phone     String
  vehicle   String
  plate     String

  // Campos adicionais para o PDF
  document  String?  // CPF/CNPJ do cliente
  address   String?  // Endereço do cliente

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  appointments Appointment[]
  budgets      Budget[]
  invoices     Invoice[]
  estimates    Estimate[]
}

//////////////////// REFRESH TOKENS ////////////////////
model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

//////////////////// AGENDAMENTOS ////////////////////
model Appointment {
  id        Int      @id @default(autoincrement())
  clientId  Int
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  date      DateTime
  comment   String?

  createdAt DateTime @default(now())

  // Relações
  notifications Notification[]
}

//////////////////// ORÇAMENTOS ////////////////////
model Estimate {
  id        Int            @id @default(autoincrement())
  tenantId  String
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId  Int
  client    Client         @relation(fields: [clientId], references: [id])

  date      DateTime
  total     Float
  status    EstimateStatus @default(DRAFT)

  // Campos para compartilhamento via WhatsApp
  shareToken       String?   @unique
  shareTokenExpires DateTime?

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  // Relações
  items   EstimateItem[]
  invoice Invoice?        // Relação 1:1 opcional (chave estrangeira em Invoice)
}

model EstimateItem {
  id          Int      @id @default(autoincrement())
  estimateId  Int
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  description String
  quantity    Int
  price       Float
  total       Float
  issPercent  Float?

  @@unique([estimateId, id])
}

//////////////////// ORÇAMENTOS (versão antiga, manter compatibilidade) ////////////////////
model Budget {
  id        Int      @id @default(autoincrement())
  clientId  Int
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tenantId  String
  items     String
  total     Float
  status    String
  createdAt DateTime @default(now())
}

//////////////////// FATURAS ////////////////////
model Invoice {
  id         Int @id @default(autoincrement())

  tenantId   String
  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clientId   Int
  client     Client @relation(fields: [clientId], references: [id])

  estimateId Int?   @unique
  estimate   Estimate? @relation(fields: [estimateId], references: [id])

  total      Float
  number     String @unique
  status     InvoiceStatus @default(PENDING)

  createdAt  DateTime @default(now())

  // Campos para compartilhamento via WhatsApp
  shareToken       String?   @unique
  shareTokenExpires DateTime?

  // Relações
  items      InvoiceItem[]
}

model InvoiceItem {
  id          Int     @id @default(autoincrement())
  invoiceId   Int
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  description String
  quantity    Int
  price       Float
  total       Float
  issPercent  Float?

  @@unique([invoiceId, id])
}

//////////////////// NOTIFICAÇÕES ////////////////////
model Notification {
  id        Int      @id @default(autoincrement())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title     String
  message   String
  isGlobal  Boolean  @default(false)
  read      Boolean  @default(false)

  createdAt DateTime @default(now())

  // Relação opcional com o agendamento que gerou a notificação
  appointmentId Int?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
}

//////////////////// NOTIFICAÇÕES AGENDADAS (para o admin) ////////////////////
model ScheduledNotification {
  id        String   @id @default(uuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title     String
  message   String
  target    String   // 'all' ou 'specific'
  schedule  DateTime
  sent      Boolean  @default(false)

  createdAt DateTime @default(now())
}